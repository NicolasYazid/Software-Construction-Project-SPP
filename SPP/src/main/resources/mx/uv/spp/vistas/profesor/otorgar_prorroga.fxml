<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<!--
    otorgar_prorroga.fxml — CU-30: Otorgar Prórroga (Profesor).
    Controlador:
      mx.uv.spp.controladores.profesor.OtorgarProrrogaController
-->
<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller=
        "mx.uv.spp.controladores.profesor.OtorgarProrrogaController"
      spacing="10.0">
    <padding>
        <Insets top="20.0" right="20.0"
                bottom="20.0" left="20.0" />
    </padding>

    <Label text="Otorgar Prórroga"
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <Label fx:id="lblEstado"
           wrapText="true"
           maxWidth="Infinity"
           style="-fx-text-fill: #1C3A6E;" />

    <Separator />

    <GridPane hgap="10.0" vgap="8.0">
        <Label text="ID del documento:"
               GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtIdDocumento" prefWidth="200.0"
                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Nueva fecha límite:"
               GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <DatePicker fx:id="dtpFechaProrroga"
                    GridPane.columnIndex="1" GridPane.rowIndex="1" />
    </GridPane>

    <Button fx:id="btnOtorgar"
            text="Otorgar prórroga"
            onAction="#onBtnOtorgar"
            style="-fx-background-color: #1C3A6E;
                   -fx-text-fill: white;" />

</VBox>
