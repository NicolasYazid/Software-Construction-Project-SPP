<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    login.fxml — Pantalla de autenticación del SPP.
    Controlador: mx.uv.spp.controladores.comun.LoginController
    Sin lógica de negocio ni acceso a BD; todo se delega al controlador.
-->
<StackPane xmlns="http://javafx.com/javafx/8.0.171"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="mx.uv.spp.controladores.comun.LoginController"
           styleClass="fondo-login"
           stylesheets="@../css/login.css">

    <!-- ── Tarjeta central: dos columnas ────────────────────── -->
    <HBox styleClass="tarjeta-login" alignment="CENTER_LEFT">

        <!-- ── Panel izquierdo: identidad institucional ──────── -->
        <VBox styleClass="panel-marca" alignment="CENTER" spacing="10.0">
            <padding>
                <Insets top="48.0" right="40.0"
                        bottom="48.0" left="40.0" />
            </padding>

            <Label text="SPP" styleClass="lbl-marca-siglas" />
            <Label text="Sistema de Prácticas"
                   styleClass="lbl-marca-linea" />
            <Label text="Profesionales"
                   styleClass="lbl-marca-linea" />

            <Separator styleClass="separador-marca">
                <VBox.margin><Insets top="6.0" bottom="6.0" /></VBox.margin>
            </Separator>

            <Label text="FEI · Universidad Veracruzana"
                   styleClass="lbl-marca-inst"
                   wrapText="true" alignment="CENTER" />
            <Label text="Xalapa, Veracruz · FEB–JUL 2026"
                   styleClass="lbl-marca-periodo" />
        </VBox>

        <!-- ── Panel derecho: formulario de acceso ───────────── -->
        <VBox styleClass="panel-formulario" spacing="6.0"
              HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="48.0" right="48.0"
                        bottom="48.0" left="48.0" />
            </padding>

            <Label text="Iniciar sesión"
                   styleClass="lbl-titulo-form" />
            <Label text="Acceda con las credenciales que le asignó el coordinador."
                   styleClass="lbl-subtitulo-form" wrapText="true" />

            <!-- ── Selector de rol ──────────────────────────── -->
            <VBox spacing="4.0">
                <VBox.margin><Insets top="16.0" /></VBox.margin>
                <Label text="Tipo de usuario:" styleClass="lbl-campo" />
                <ComboBox fx:id="cmbTipo" styleClass="cmb-login"
                          maxWidth="Infinity"
                          promptText="Seleccione su rol" />
            </VBox>

            <!-- ── Identificador (correo o matrícula) ──────── -->
            <VBox spacing="4.0">
                <VBox.margin><Insets top="8.0" /></VBox.margin>
                <Label fx:id="lblIdentificador"
                       text="Correo electrónico:"
                       styleClass="lbl-campo" />
                <TextField fx:id="txtIdentificador"
                           styleClass="txt-login"
                           maxWidth="Infinity"
                           promptText="Ingrese su correo electrónico" />
            </VBox>

            <!-- ── Contraseña ───────────────────────────────── -->
            <VBox spacing="4.0">
                <VBox.margin><Insets top="8.0" /></VBox.margin>
                <Label text="Contraseña:" styleClass="lbl-campo" />
                <PasswordField fx:id="pwdContrasena"
                               styleClass="txt-login"
                               maxWidth="Infinity"
                               promptText="Ingrese su contraseña" />
            </VBox>

            <!-- ── Botón de acceso ──────────────────────────── -->
            <Button fx:id="btnIniciarSesion"
                    text="Ingresar"
                    styleClass="btn-login"
                    maxWidth="Infinity"
                    defaultButton="true"
                    onAction="#onBtnIniciarSesion">
                <VBox.margin><Insets top="20.0" /></VBox.margin>
            </Button>

            <!-- ── Etiqueta de mensajes (error / info) ──────── -->
            <Label fx:id="lblMensaje"
                   styleClass="lbl-mensaje-oculto"
                   wrapText="true" maxWidth="Infinity">
                <VBox.margin><Insets top="4.0" /></VBox.margin>
            </Label>

        </VBox>
    </HBox>

</StackPane>
