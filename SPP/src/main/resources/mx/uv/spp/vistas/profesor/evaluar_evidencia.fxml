<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<!--
    evaluar_evidencia.fxml — CU-29: Evaluar Evidencia (Profesor).
    Controlador:
      mx.uv.spp.controladores.profesor.EvaluarEvidenciaController
-->
<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller=
        "mx.uv.spp.controladores.profesor.EvaluarEvidenciaController"
      spacing="10.0" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="20.0" right="20.0"
                bottom="20.0" left="20.0" />
    </padding>

    <Label text="Evidencias por Evaluar"
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <Label fx:id="lblEstado"
           wrapText="true"
           maxWidth="Infinity"
           style="-fx-text-fill: #1C3A6E;" />

    <TableView fx:id="tblEvidencias" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colInscripcion"
                         text="Inscripción"
                         prefWidth="100.0" />
            <TableColumn fx:id="colTipo"
                         text="Tipo de evidencia"
                         prefWidth="200.0" />
            <TableColumn fx:id="colArchivo"
                         text="Archivo"
                         prefWidth="250.0" />
            <TableColumn fx:id="colAccion"
                         text="Acciones"
                         prefWidth="160.0" />
        </columns>
    </TableView>

</VBox>
