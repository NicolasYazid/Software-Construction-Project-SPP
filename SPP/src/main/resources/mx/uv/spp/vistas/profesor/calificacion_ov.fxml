<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<!--
    calificacion_ov.fxml — CU-Est.-27: Asignar Calificación OV.
    Controlador:
      mx.uv.spp.controladores.profesor.CalificacionOVController
-->
<VBox xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller=
        "mx.uv.spp.controladores.profesor.CalificacionOVController"
      spacing="10.0" VBox.vgrow="ALWAYS">
    <padding>
        <Insets top="20.0" right="20.0"
                bottom="20.0" left="20.0" />
    </padding>

    <Label text="Calificación de la OV"
           style="-fx-font-size: 16px; -fx-font-weight: bold;" />

    <Label fx:id="lblEstado"
           wrapText="true"
           maxWidth="Infinity"
           style="-fx-text-fill: #1C3A6E;" />

    <TableView fx:id="tblOV" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colEstudiante"
                         text="Estudiante ID"
                         prefWidth="110.0" />
            <TableColumn fx:id="colTipo"
                         text="Tipo de Evaluación"
                         prefWidth="200.0" />
            <TableColumn fx:id="colArchivo"
                         text="Archivo"
                         prefWidth="220.0" />
            <TableColumn fx:id="colAccion"
                         text="Acciones"
                         prefWidth="160.0" />
        </columns>
    </TableView>

</VBox>
