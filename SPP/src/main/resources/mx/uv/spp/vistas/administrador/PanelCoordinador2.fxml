<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    PanelCoordinador2.fxml — Panel principal del Administrador.
    Controlador:
        mx.uv.spp.controladores.administrador.PanelCoordinador2Controller
-->
<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller=
              "mx.uv.spp.controladores.administrador.PanelCoordinador2Controller"
            prefHeight="700.0" prefWidth="1100.0"
            stylesheets="@css/panelcoordinador2.css">

    <!-- ── Barra lateral izquierda ───────────────────────────── -->
    <left>
        <VBox styleClass="sidebar" spacing="8.0"
              prefWidth="220.0" prefHeight="700.0">
            <padding>
                <Insets top="28.0" right="12.0"
                        bottom="24.0" left="12.0" />
            </padding>

            <!-- Logo y título del sistema -->
            <Label text="SPP"
                   maxWidth="Infinity"
                   styleClass="lbl-sidebar-logo" />

            <Separator styleClass="separador-sidebar" />

            <!-- Sección de control académico -->
            <Label text="Control del personal académico"
                   wrapText="true"
                   styleClass="lbl-sidebar-seccion" />

            <Button fx:id="btnProfesores"
                    text="Profesores"
                    maxWidth="Infinity"
                    onAction="#onBtnProfesores"
                    styleClass="btn-menu" />

            <Button fx:id="btnCoordinador"
                    text="Coordinador"
                    maxWidth="Infinity"
                    onAction="#onBtnCoordinador"
                    styleClass="btn-menu" />

            <!-- Empuja el botón de cerrar sesión al fondo -->
            <Region VBox.vgrow="ALWAYS" />

            <Separator styleClass="separador-sidebar" />

            <Button fx:id="btnCerrarSesion"
                    text="Cerrar sesión"
                    maxWidth="Infinity"
                    onAction="#onBtnCerrarSesion"
                    styleClass="btn-cerrar-sesion" />
        </VBox>
    </left>

    <!-- ── Área central de contenido ────────────────────────── -->
    <center>
        <StackPane fx:id="contenedor" styleClass="area-contenido">

            <!-- Vista de bienvenida inicial -->
            <VBox fx:id="panelBienvenida"
                  styleClass="panel-bienvenida"
                  spacing="16.0">

                <Label text="SPP"
                       styleClass="lbl-bienvenida-siglas" />

                <Label text="Bienvenido al sistema de Prácticas Profesionales de Ingeniería de Software"
                       wrapText="true"
                       styleClass="lbl-bienvenida-titulo" />

                <Label text="Elige una de las opciones del panel izquierdo para poder realizar una operación"
                       wrapText="true"
                       styleClass="lbl-bienvenida-instruccion" />
            </VBox>

        </StackPane>
    </center>

</BorderPane>
