<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    PanelTransferirRol.fxml — Ventana emergente (modal) que permite
    al Administrador seleccionar un Profesor activo y transferirle
    el rol de Coordinador.
    Controlador:
        mx.uv.spp.controladores.administrador
            .PanelTransferirRolController
-->
<BorderPane prefHeight="480.0" prefWidth="760.0"
            stylesheets="@css/paneltransferirrol.css"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller=
              "mx.uv.spp.controladores.administrador.PanelTransferirRolController">

    <!-- ── Título ───────────────────────────────────────────────── -->
    <top>
        <VBox styleClass="cabecera">
            <Label text="Transferir rol" styleClass="lbl-titulo" />
        </VBox>
    </top>

    <!-- ── Tabla de profesores activos ─────────────────────────── -->
    <center>
        <VBox styleClass="area-tabla">
            <padding>
                <Insets left="40.0" right="40.0" />
            </padding>

            <TableView fx:id="tblProfesores"
                       styleClass="tbl-profesores"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNumeroPersonal"
                                 text="No. Personal"
                                 prefWidth="160.0" />
                    <TableColumn fx:id="colNombre"
                                 text="Nombre"
                                 prefWidth="310.0" />
                    <TableColumn fx:id="colCorreo"
                                 text="Correo Institucional"
                                 prefWidth="260.0" />
                </columns>
                <placeholder>
                    <Label text="No hay profesores activos." />
                </placeholder>
            </TableView>

            <Label fx:id="lblMensaje"
                   wrapText="true"
                   styleClass="lbl-mensaje" />
        </VBox>
    </center>

    <!-- ── Botones centrados ────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="barra-acciones" alignment="CENTER" spacing="24.0">
            <Button fx:id="btnTransferirRol"
                    text="Transferir rol"
                    onAction="#onBtnTransferirRol"
                    styleClass="btn-accion" />
            <Button fx:id="btnRegresar"
                    text="Regresar"
                    onAction="#onBtnRegresar"
                    styleClass="btn-accion" />
        </HBox>
    </bottom>

</BorderPane>
